msgid "co2"
msgstr ""

#: of prepshot._model.co2:1
msgid ""
"This module contains the constraints and expressions related to carbon "
"emissions. The model computes the carbon emissions for each year, based "
"on the sum of carbon emissions from each zone, and from each technology "
"as follows:"
msgstr ""

#: of prepshot._model.co2:6
msgid ""
"{\\rm{carbon}}_y=\\sum_{e\\in\\mathcal{E}}\\sum_{z\\in\\mathcal{Z}}\n"
"\\sum_{m\\in\\mathcal{M}}\\sum_{h\\in\\mathcal{H}}\n"
"\\left({{\\rm{CARBON}}}_{y,z,e}\\times\n"
"{\\rm{gen}}_{h,m,y,z,e}\\right)\\quad\\forall y"
msgstr ""

#: of prepshot._model.co2:13
msgid ""
"The calculated carbon emission for each year lower than its upper bound, "
"as follows:"
msgstr ""

#: of prepshot._model.co2:15
msgid "{\\rm{carbon}}_y\\le{\\overline{{\\rm{CARBON}}}}_y\\quad\\forall y"
msgstr ""

