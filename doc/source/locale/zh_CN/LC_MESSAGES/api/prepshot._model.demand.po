#: of prepshot._model.demand:1
msgid ""
"This module contains constraints related to demand. The model computes "
"the power balance for each hour, in each time period, for each year, and "
"in each zone, as follows:"
msgstr ""

#: of prepshot._model.demand:5
msgid ""
"{{\\rm{DEMAND}}}_{h,m,y,z}\\times\\Delta h = \\sum_{z_{\\rm{from}}\\in\n"
"{\\mathcal{Z}}\\backslash{\\{z\\}}}{{\\rm{import}}_{h,m,y,z_{\\rm{from}},z}}"
"\n"
"- \\sum_{z_{\\rm{to}}\\in {\\mathcal{Z}}\\backslash{\\{z\\}}}\n"
"{{\\rm{export}}_{h,m,y,z,z_{\\rm{to}}}}\n"
"\n"
"+ \\sum_{e\\in {\\mathcal{E}}}{{\\rm{gen}}_{h,m,y,z,e}}\n"
"- \\sum_{e\\in {\\mathcal{STOR}}}{{\\rm{charge}}_{h,m,y,z,e}}\n"
"\\quad\\forall h,m,y,z"
msgstr ""

