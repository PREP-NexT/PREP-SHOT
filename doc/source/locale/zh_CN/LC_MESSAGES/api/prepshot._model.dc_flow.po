#: of prepshot._model.dc_flow.AddDCFlowConstraints.cap_c_rule:1
msgid "Capacity bound on contingency-case flow."
msgstr ""

#: of prepshot._model.dc_flow.AddDCFlowConstraints.cap_c_rule:3
msgid ""
"``trans_export_c[h, m, y, z1, z2, c] <= cap_lines_existing[y, z1, z2]``. "
"Same numeric bound as the base case -- ``gen`` is shared between base and"
" contingency, so capacity stays consistent."
msgstr ""

#: of prepshot._model.dc_flow.AddDCFlowConstraints.cap_c_rule
#: prepshot._model.dc_flow.AddDCFlowConstraints.demand_balance_c_rule
