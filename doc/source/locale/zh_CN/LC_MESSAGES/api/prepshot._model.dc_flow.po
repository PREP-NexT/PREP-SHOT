msgstr ""

#: of prepshot._model.dc_flow.AddDCFlowConstraints.demand_balance_c_rule:1
msgid "Power balance in contingency c."
msgstr ""

#: of prepshot._model.dc_flow.AddDCFlowConstraints.demand_balance_c_rule:3
msgid ""
"Same as the base-case ``power_balance_rule`` in ``demand.py``, but with "
"contingency-case flows. ``gen`` and ``charge`` are the shared base-case "
"decisions (preventive policy)."
msgstr ""

#: of prepshot._model.dc_flow.AddDCFlowConstraints.flow_c_rule:1
msgid "Per-line DC flow eq in contingency c."
msgstr ""

#: of prepshot._model.dc_flow.AddDCFlowConstraints.flow_c_rule:3
msgid ""
"The outaged line ``self.contingencies[c]`` has its flow forced to zero "
"(both directions). Every other line follows the same susceptance-times-"
"angle-difference relation as the base case."
msgstr ""

#: of prepshot._model.dc_flow.AddDCFlowConstraints.flow_rule:1
msgid "Net flow = susceptance * angle difference * dt."
msgstr ""

#: of prepshot._model.dc_flow.AddDCFlowConstraints.flow_rule:3
msgid ""
"Only emitted for ordered pairs ``(z1, z2)`` with ``z1 < z2`` and a "
"positive susceptance, so each electrical line gets one constraint instead"
" of two redundant ones. The capacity bound on each ``trans_export`` "
"direction stays in place."
msgstr ""

