# Log and output directories
/log/*
!/log/.gitkeep

/output/*
!/output/.gitkeep

# Python compiled files and other common Python ignores
*.pyc
*.pyo
*.egg-info/
__pycache__/

# Sphinx documentation builds
/doc/build/

# Common development files
*.log
*.swp
*.swo
.DS_Store

# Scenario / debugging input directories (kept locally, not part of repo)
/input_s*/

# Solver license files
/y/
*.lic

# Claude Code skills (local; not part of public repo)
/.claude/
