# Runtime log and output directories. Auto-created by set_up.py /
# output_data.py at run time; never tracked. Match anywhere in the
# tree (each example's own log/ and output/ are also runtime).
log/
output/

# Python compiled files and other common Python ignores
*.pyc
*.pyo
*.egg-info/
__pycache__/
/.pytest_cache/

# Sphinx documentation builds
/doc/build/

# Compiled gettext message catalogs (regenerated from .po on each build).
*.mo

# Common development files
*.log
*.swp
*.swo
.DS_Store


# Claude Code skills (local; not part of public repo)
/.claude/

# Local copies of NREL/DOE primer PDFs (linked from doc/source/index.rst
# and Glossary.rst).  Backups for offline reading; not part of the
# repo to avoid bloating clones.
references/

# Thailand PCM example: large generated CSVs (regenerate via
# examples/thailand_pcm/build_inputs.py from the upstream
# production-cost-model-main dataset, which is not vendored here).
examples/thailand_pcm/input/
examples/thailand_pcm/output/
examples/thailand_pcm/log/
# Downloaded once by the notebook (johan/world.geo.json), ~5 KB.
examples/thailand_pcm/thailand_outline.geojson
