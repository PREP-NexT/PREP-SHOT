#!/bin/bash
# Binder runs this after building the conda environment from
# environment.yml. We install PREP-SHOT itself in editable mode
# (its runtime dependencies -- pyoptinterface, highsbox, xarray,
# pandas -- are pulled in via the package's pyproject.toml). The
# notebook extras (jupyterlab, matplotlib, h5netcdf) are installed
# from environment.yml.
set -euxo pipefail

pip install -e .
